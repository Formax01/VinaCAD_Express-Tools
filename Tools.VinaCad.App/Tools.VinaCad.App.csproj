<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Library</OutputType>
    <LangVersion>latest</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <Configurations>Debug;Release;V2026</Configurations>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='V2026|AnyCPU'">
    <TargetFramework>net8.0-windows</TargetFramework>
    <DefineConstants>$(DefineConstants);V2026</DefineConstants>
    <OutputPath>..\Outcome_V2026\</OutputPath>
    <Nullable>enable</Nullable>
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
  </PropertyGroup>

  <ItemGroup Condition="'$(Configuration)' == 'V2026'">
    <Reference Include="TD_Mgd_Net8_26.12_17">
      <HintPath>..\Lib\VinaCad\2026\TD_Mgd_Net8_26.12_17.dll</HintPath>
    </Reference>
    <Reference Include="VinaCADCoreMgd_Net8">
      <HintPath>..\Lib\VinaCad\2026\VinaCADCoreMgd_Net8.dll</HintPath>
    </Reference>
    <Reference Include="PrLogTrackingSystem">
      <HintPath>..\Lib\PR\2026\PrLogTrackingSystem.dll</HintPath>
    </Reference>
    <Reference Include="PrMVVMCore">
      <HintPath>..\Lib\PR\2026\PrMVVMCore.dll</HintPath>
    </Reference>
    <ProjectReference Include="..\Tools.VinaCad.Action\Tools.VinaCad.Action.csproj" />
    <ProjectReference Include="..\Resources\Tools.Resources.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Update="ApplicationLoader\VinaCAD_ExpressTools.cuix">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
    <None Update="Log4net.config">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
    <None Update="VinaCAD_ExpressTools.cuix">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
