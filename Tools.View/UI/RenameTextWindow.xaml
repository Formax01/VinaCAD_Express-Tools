<Window
    x:Class="Tools.View.UI.RenameTextWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Tools.View.UI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Đổi tên Text"
    Width="460"
    Height="450"
    ResizeMode="CanResize"
    Topmost="True"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <!--  DataGrid  -->
        <DataGrid
            x:Name="dgDanhMuc"
            Grid.Row="0"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            GridLinesVisibility="All"
            HeadersVisibility="Column"
            ItemsSource="{Binding CauKienItems}"
            KeyDown="dgDanhMuc_KeyDown"
            SelectionMode="Extended"
            SelectionUnit="Cell">

            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                    <Setter Property="Height" Value="24" />
                    <Setter Property="FontWeight" Value="Normal" />
                </Style>

                <Style TargetType="DataGridCell">
                    <Setter Property="Padding" Value="3,0,3,0" />
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                </Style>

                <Style TargetType="TextBlock">
                    <Setter Property="VerticalAlignment" Value="Center" />
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                    Header="Text cũ" />

                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding NewText, UpdateSourceTrigger=PropertyChanged}"
                    Header="Text mới" />
            </DataGrid.Columns>
        </DataGrid>

        <!--  Bottom area  -->
        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="80" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  Option group  -->
            <GroupBox Grid.Row="0" Header="Kiểu thay thế?">

                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">

                    <RadioButton
                        Margin="0,0,35,0"
                        VerticalAlignment="Center"
                        Content="Ghi đè"
                        FontSize="11"
                        GroupName="RenameType"
                        IsChecked="{Binding IsOverride}" />

                    <RadioButton
                        VerticalAlignment="Center"
                        Content="Cộng dồn"
                        FontSize="11"
                        GroupName="RenameType"
                        IsChecked="{Binding IsIncludingOldAndNew}" />
                </StackPanel>
            </GroupBox>

            <!--  Buttons  -->
            <Grid Grid.Row="1" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="50" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="50" />

                </Grid.ColumnDefinitions>
                <Button
                    Grid.Column="1"
                    Width="70"
                    Height="25"
                    HorizontalAlignment="Center"
                    Command="{Binding OkCmd}"
                    Content="Ok"
                    FontSize="11" />

                <Button
                    Grid.Column="2"
                    Width="70"
                    Height="25"
                    HorizontalAlignment="Center"
                    Command="{Binding CancelCmd}"
                    Content="Thoát"
                    FontSize="11" />
            </Grid>
        </Grid>
    </Grid>
</Window>
