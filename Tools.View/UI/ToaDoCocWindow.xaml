<Window
    x:Class="Tools.View.UI.ToaDoCocWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Tools.View.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Tools.View.UI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Xác Lập Tọa độ cọc"
    Width="400"
    ResizeMode="NoResize"
    SizeToContent="Height"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock
                VerticalAlignment="Center"
                Text="K.cách lệch cho phép giữa cọc và kí hiệu cọc:"
                TextWrapping="Wrap" />
            <TextBox
                Grid.Column="1"
                HorizontalContentAlignment="Right"
                VerticalContentAlignment="Center"
                behaviors:TextBoxBehavior.SelectAllTextOnFocus="True"
                Text="{Binding CheckDistance, UpdateSourceTrigger=PropertyChanged}" />
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock VerticalAlignment="Center" Text="Tỷ lệ bản vẽ:" />

            <TextBox
                Grid.Column="1"
                HorizontalContentAlignment="Left"
                VerticalContentAlignment="Center"
                behaviors:TextBoxBehavior.SelectAllTextOnFocus="True"
                Text="{Binding Scale, UpdateSourceTrigger=PropertyChanged}" />
        </Grid>
        <StackPanel
            Grid.Row="2"
            Grid.ColumnSpan="2"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Orientation="Horizontal">

            <Button
                Width="70"
                Height="25"
                Margin="0,0,90,0"
                Command="{Binding SelectPileCmd}"
                Content="Quét chọn" />

            <Button
                Width="70"
                Height="25"
                Command="{Binding CancelCmd}"
                Content="Thoát" />
        </StackPanel>
    </Grid>
</Window>
