<Window
    x:Class="Tools.View.UI.DrawingCategoriesWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Tools.View.UI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Thống Kê Danh Mục"
    Width="650"
    Height="650"
    Loaded="BangToaDoCocWindow_Loaded"
    ResizeMode="CanResize"
    mc:Ignorable="d">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <DataGrid
            x:Name="dgDanhMuc"
            Grid.Row="0"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            ItemsSource="{Binding DrawingItems}"
            KeyDown="dgDanhMuc_KeyDown"
            SelectionMode="Extended"
            SelectionUnit="Cell">

            <DataGrid.Columns>

                <!--  STT  -->
                <DataGridTextColumn
                    Width="80"
                    Binding="{Binding STT, UpdateSourceTrigger=PropertyChanged}"
                    Header="STT"
                    SortMemberPath="STT">

                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.HeaderStyle>

                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="TextAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>

                    <DataGridTextColumn.EditingElementStyle>
                        <Style TargetType="TextBox">
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                            <Setter Property="TextAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.EditingElementStyle>

                </DataGridTextColumn>

                <!--  TÊN BẢN VẼ  -->
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding DrawingName, UpdateSourceTrigger=PropertyChanged}"
                    Header="Tên Bản Vẽ"
                    SortMemberPath="DrawingName">
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                </DataGridTextColumn>
                <!--  SỐ HIỆU  -->
                <DataGridTextColumn
                    Width="100"
                    Binding="{Binding DrawingNo, UpdateSourceTrigger=PropertyChanged}"
                    Header="Số Hiệu"
                    SortMemberPath="DrawingNo">
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="TextAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>

                    <DataGridTextColumn.EditingElementStyle>
                        <Style TargetType="TextBox">
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                            <Setter Property="TextAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.EditingElementStyle>

                </DataGridTextColumn>

            </DataGrid.Columns>
        </DataGrid>

        <StackPanel
            Grid.Row="1"
            Margin="0,10,0,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Orientation="Horizontal">

            <Button
                Width="70"
                Height="25"
                Margin="0,0,70,0"
                Command="{Binding DrawTableCmd}"
                Content="Vẽ bảng" />

            <Button
                Width="70"
                Height="25"
                Command="{Binding CancelCmd}"
                Content="Thoát" />
        </StackPanel>
    </Grid>
</Window>
