<Window
    x:Class="Tools.View.UI.VeCocWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Tools.View.UI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Vẽ Cọc"
    Width="450"
    Height="450"
    Topmost="True"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DataGrid
            x:Name="dgDanhMuc"
            Grid.Row="0"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            GridLinesVisibility="All"
            HeadersVisibility="All"
            ItemsSource="{Binding CauKienItems}"
            KeyDown="dgDanhMuc_KeyDown"
            SelectionMode="Extended"
            SelectionUnit="Cell">
            <DataGrid.Columns>

                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding SoHieu, UpdateSourceTrigger=PropertyChanged}"
                    Header="Số Hiệu">

                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.HeaderStyle>

                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextAlignment" Value="Center" />
                            <Setter Property="HorizontalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>

                </DataGridTextColumn>


                <DataGridTextColumn
                    Width="1.5*"
                    Binding="{Binding ToaDoX, UpdateSourceTrigger=PropertyChanged}"
                    Header="Tọa Độ X">

                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.HeaderStyle>

                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextAlignment" Value="Center" />
                            <Setter Property="HorizontalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>

                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="1.5*"
                    Binding="{Binding ToaDoY, UpdateSourceTrigger=PropertyChanged}"
                    Header="Tọa Độ Y">

                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.HeaderStyle>

                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextAlignment" Value="Center" />
                            <Setter Property="HorizontalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>

                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
        <GroupBox
            Grid.Row="1"
            Width="320"
            Height="60"
            Margin="0,10,0,10"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Header="Tọa độ cọc của bạn là m hay mm?">

            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Horizontal">

                <RadioButton
                    Margin="0,0,60,0"
                    Content="Met"
                    GroupName="CoordinateUnit"
                    IsChecked="{Binding IsMeter}" />

                <RadioButton
                    Content="Milimet"
                    GroupName="CoordinateUnit"
                    IsChecked="{Binding IsMillimeter}" />

            </StackPanel>
        </GroupBox>
        <StackPanel
            Grid.Row="2"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Orientation="Horizontal">

            <Button
                Width="70"
                Height="25"
                Margin="0,0,70,0"
                Command="{Binding VeCocCmd}"
                Content="Vẽ Cọc" />

            <Button
                Width="70"
                Height="25"
                Command="{Binding CancelCmd}"
                Content="Thoát" />
        </StackPanel>
    </Grid>
</Window>
