<Window
    x:Class="Tools.View.UI.XLTKCTWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Tools.View.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Tools.View.UI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Xác Lập Thống Kê Cốt Thép"
    ResizeMode="NoResize"
    SizeToContent="WidthAndHeight"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Grid Background="#9DB9D3">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="10" />
        </Grid.RowDefinitions>

        <!--  PHẦN 1  -->
        <GroupBox
            Grid.Row="0"
            Margin="10"
            Header="Chiều Dài Mối Nối:">

            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Text="D &lt; 10:" />

                <TextBox
                    Grid.Row="0"
                    Grid.Column="1"
                    Width="140"
                    HorizontalContentAlignment="Right"
                    VerticalContentAlignment="Center"
                    behaviors:TextBoxBehavior.SelectAllTextOnFocus="True"
                    Foreground="Red"
                    Text="{Binding LapD10}" />

                <TextBlock
                    Grid.Row="0"
                    Grid.Column="2"
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    Text="*D" />

                <TextBlock
                    Grid.Row="2"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Text="10 &lt;= D &lt;= 16:" />

                <TextBox
                    Grid.Row="2"
                    Grid.Column="1"
                    Width="140"
                    HorizontalContentAlignment="Right"
                    VerticalContentAlignment="Center"
                    behaviors:TextBoxBehavior.SelectAllTextOnFocus="True"
                    Foreground="Red"
                    Text="{Binding LapD10D16}" />

                <TextBlock
                    Grid.Row="2"
                    Grid.Column="2"
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    Text="*D" />

                <TextBlock
                    Grid.Row="4"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Text="16 &lt; D:" />

                <TextBox
                    Grid.Row="4"
                    Grid.Column="1"
                    Width="140"
                    HorizontalContentAlignment="Right"
                    VerticalContentAlignment="Center"
                    behaviors:TextBoxBehavior.SelectAllTextOnFocus="True"
                    Foreground="Red"
                    Text="{Binding LapD16}" />

                <TextBlock
                    Grid.Row="4"
                    Grid.Column="2"
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    Text="*D" />

                <TextBlock
                    Grid.Row="6"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Text="Phần DUL thêm:" />

                <TextBox
                    Grid.Row="6"
                    Grid.Column="1"
                    Width="140"
                    HorizontalContentAlignment="Right"
                    VerticalContentAlignment="Center"
                    behaviors:TextBoxBehavior.SelectAllTextOnFocus="True"
                    Foreground="Red"
                    Text="{Binding DulThem}" />
            </Grid>
        </GroupBox>

        <!--  PHẦN 2  -->
        <GroupBox
            Grid.Row="1"
            Margin="10,0,10,0"
            Header="Chiều Dài Bẻ Móc Thép Đai:">

            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>

                <RadioButton
                    Grid.Row="0"
                    Grid.Column="0"
                    VerticalContentAlignment="Center"
                    Content="Tính Động Đất:"
                    GroupName="HookType"
                    IsChecked="{Binding IsDongDat}" />

                <TextBox
                    Grid.Row="0"
                    Grid.Column="1"
                    Width="140"
                    HorizontalContentAlignment="Right"
                    VerticalContentAlignment="Center"
                    behaviors:TextBoxBehavior.SelectAllTextOnFocus="True"
                    Foreground="Red"
                    Text="{Binding HookEarthquake}" />

                <TextBlock
                    Grid.Row="0"
                    Grid.Column="2"
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    Text="*D" />

                <RadioButton
                    Grid.Row="2"
                    Grid.Column="0"
                    VerticalContentAlignment="Center"
                    Content="Không Tính Động Đất:"
                    GroupName="HookType"
                    IsChecked="{Binding IsNotDongDat}" />

                <TextBox
                    Grid.Row="2"
                    Grid.Column="1"
                    Width="140"
                    HorizontalContentAlignment="Right"
                    VerticalContentAlignment="Center"
                    behaviors:TextBoxBehavior.SelectAllTextOnFocus="True"
                    Foreground="Red"
                    Text="{Binding HookNormal}" />

                <TextBlock
                    Grid.Row="2"
                    Grid.Column="2"
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    Text="*D" />
            </Grid>
        </GroupBox>

        <!--  BUTTON  -->
        <Grid Grid.Row="3" HorizontalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="50" />
                <ColumnDefinition Width="80" />
            </Grid.ColumnDefinitions>

            <Button
                Grid.Column="0"
                Width="70"
                Height="25"
                Click="Button_Click"
                Command="{Binding XacLapCmd}"
                Content="Xác Lập"
                Foreground="Blue" />

            <Button
                Grid.Column="2"
                Width="70"
                Height="25"
                Command="{Binding CancelCmd}"
                Content="Thoát"
                Foreground="Blue" />
        </Grid>

    </Grid>
</Window>