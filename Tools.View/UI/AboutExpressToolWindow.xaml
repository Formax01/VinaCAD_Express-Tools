<Window
    x:Class="Tools.View.UI.AboutExpressToolWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Tools.View.UI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Thông tin Express_Tools"
    Width="340"
    SizeToContent="Height"
    WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,10"
            FontSize="22"
            Foreground="Black"
            Text="Express_Tools" />

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Top">
                <TextBlock Margin="0,0,0,4" Foreground="Black">
                    <Run Text="Phiên bản hiện tại " />
                    <Run Text="{Binding CurrentVersion}" />
                </TextBlock>

                <TextBlock Foreground="Black" Text="Formax Technologies" />
            </StackPanel>

            <TextBlock
                Grid.Column="1"
                Margin="10,10,0,0"
                VerticalAlignment="Top">

                <Hyperlink
                    Command="{Binding HyperlinkCmd}"
                    Cursor="Hand"
                    TextDecorations="Underline">
                    Hướng dẫn sử dụng
                </Hyperlink>
            </TextBlock>
        </Grid>

        <Button
            Grid.Row="2"
            Width="70"
            Height="25"
            HorizontalAlignment="Right"
            Command="{Binding CloseCmd}"
            Content="OK" />
    </Grid>
</Window>