<Window
    x:Class="Tools.View.UI.DanhSoHieuTKTSWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Tools.View.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Tools.View.UI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Đánh Số Hiệu Và Thống Kê Thép Sàn Tự Động"
    Loaded="BangToaDoCocWindow_Loaded"
    ResizeMode="NoResize"
    SizeToContent="WidthAndHeight"
    Topmost="True"
    mc:Ignorable="d">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <GroupBox
            Grid.Row="0"
            Margin="0,0,0,10"
            Header="Xác lập chiều dài bẻ móc thép và chiều dày lớp bê tông bảo vệ">
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30" />
                    <RowDefinition Height="30" />
                    <RowDefinition Height="30" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="80" />
                </Grid.ColumnDefinitions>

                <RadioButton
                    Grid.Row="0"
                    Grid.Column="0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Content="Cố định cho tất cả thanh thép"
                    GroupName="DaiMocThep"
                    IsChecked="{Binding IsCoDinh}" />
                <TextBox
                    Grid.Row="0"
                    Grid.Column="1"
                    HorizontalContentAlignment="Right"
                    VerticalContentAlignment="Center"
                    behaviors:TextBoxBehavior.SelectAllTextOnFocus="True"
                    Foreground="Red"
                    Text="{Binding HookLength}" />
                <TextBlock
                    Grid.Row="0"
                    Grid.Column="2"
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    Text="(mm)" />

                <RadioButton
                    Grid.Row="1"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Content="Chiều dài thực trong bản vẽ"
                    GroupName="DaiMocThep"
                    IsChecked="{Binding IsThucTe}" />
                <TextBlock
                    Grid.Row="2"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Text="Chiều dày lớp bê tông bảo vệ:" />
                <TextBox
                    Grid.Row="2"
                    Grid.Column="1"
                    HorizontalContentAlignment="Right"
                    VerticalContentAlignment="Center"
                    behaviors:TextBoxBehavior.SelectAllTextOnFocus="True"
                    Foreground="Red"
                    Text="{Binding ChieuDayBTBaoVe}" />
                <TextBlock
                    Grid.Row="2"
                    Grid.Column="2"
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    Text="(mm)" />
            </Grid>
        </GroupBox>

        <GroupBox
            Grid.Row="1"
            Margin="0,0,0,10"
            Header="Xác lập đánh số hiệu thép sàn tự động">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="30" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Text="Quy tắc đánh số hiệu:" />
                <RadioButton
                    Grid.Row="0"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Content="Trái sang phải"
                    GroupName="HuongBoTri"
                    IsChecked="{Binding IsLeftToRight}" />
                <RadioButton
                    Grid.Row="0"
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Content="Trên xuống dưới"
                    GroupName="HuongBoTri"
                    IsChecked="{Binding IsTopToBottom}" />

                <TextBlock
                    Grid.Row="2"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Text="Số hiệu bắt đầu (cố định):" />
                <TextBox
                    Grid.Row="2"
                    Grid.Column="1"
                    Width="100"
                    HorizontalContentAlignment="Left"
                    VerticalContentAlignment="Center"
                    behaviors:TextBoxBehavior.SelectAllTextOnFocus="True"
                    Foreground="Red"
                    Text="{Binding SoHieuStart}" />
            </Grid>
        </GroupBox>

        <GroupBox
            Grid.Row="2"
            Margin="0,0,0,10"
            Header="Xác lập tỷ lệ bản vẽ">
            <Grid Height="30" Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Text="Tỷ lệ bản vẽ:" />
                <TextBox
                    Grid.Column="1"
                    HorizontalContentAlignment="Left"
                    VerticalContentAlignment="Center"
                    behaviors:TextBoxBehavior.SelectAllTextOnFocus="True"
                    Foreground="Red"
                    Text="{Binding Scale}" />
            </Grid>
        </GroupBox>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button
                Grid.Column="0"
                Width="100"
                Height="40"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Command="{Binding DanhSoCmd}">

                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Text="Đánh Số Hiệu&#x0a;Tự Động"
                    TextAlignment="Center" />
            </Button>

            <Button
                Grid.Column="1"
                Width="100"
                Height="40"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Command="{Binding DrawTableCmd}">

                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Text="Vẽ Bảng Thống&#x0a;Kê Thép"
                    TextAlignment="Center" />
            </Button>

            <Button
                Grid.Column="2"
                Width="100"
                Height="40"
                HorizontalContentAlignment="Center"
                Command="{Binding CancelCmd}"
                Content="Thoát" />
        </Grid>
    </Grid>
</Window>